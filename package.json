{
  "name": "rexmatch",
  "version": "1.0.0",
  "description": "RexMatch - Your prehistoric wingman. Automated Tinder swiping and messaging powered by Playwright.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "swipe": "node src/index.js --mode=swipe",
    "chat": "node src/index.js --mode=chat",
    "full": "node src/index.js --mode=full",
    "setup": "playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "dotenv": "^16.3.1",
    "anthropic": "^0.32.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "figlet": "^1.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
